# =============================================================
# BotDeriv1 — Configuração de Ambiente
# Copie este arquivo: cp .env.example .env
# NUNCA commite o .env com credenciais reais!
# =============================================================

# ── Deriv App ID (alfanumérico, ex: 33wQj4vvambGV9iRyHOTh) ──
# Gere em: https://developers.deriv.com → My Apps → Register
DERIV_APP_ID=SEU_APP_ID_AQUI

# ── Personal Access Tokens (PAT) ─────────────────────────────
# Gere em: https://app.deriv.com/account/api-token
# Formato novo: pat_<64 chars hex>
# Escopos necessários: read, trade, trading_information
DERIV_API_TOKEN_DEMO=pat_SEU_TOKEN_DEMO_AQUI
DERIV_API_TOKEN_REAL=pat_SEU_TOKEN_REAL_AQUI

# ── Modo padrão ao iniciar ────────────────────────────────────
# demo | real
DEFAULT_MODE=demo

# ── OAuth 2.0 (opcional — apenas para fluxo interativo) ───────
# URI de redirecionamento cadastrada no painel de desenvolvedor
OAUTH_REDIRECT_URI=http://localhost:8080/callback

# ── WebSocket endpoint (não altere sem necessidade) ───────────
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3
