# ─── Deriv API — Credenciais ────────────────────────────────────────────────
# Portal: https://developers.deriv.com

# App ID alfanumérico (novo formato, ex: 33wQj4vvambGV9iRyHOTh)
DERIV_APP_ID=SEU_APP_ID_AQUI

# Personal Access Token (PAT) — formato: pat_<64 chars hex>
# Escopos necessários: read, trade, trading_information
# Gere em: https://app.deriv.com/account/api-token
DERIV_API_TOKEN_DEMO=pat_SEU_TOKEN_DEMO_AQUI
DERIV_API_TOKEN_REAL=pat_SEU_TOKEN_REAL_AQUI

# URI de callback OAuth 2.0 (padrão local para dev)
OAUTH_REDIRECT_URI=http://localhost:8080/callback

# Modo padrão ao iniciar: demo | real
DEFAULT_MODE=demo

# WebSocket endpoint (não alterar)
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3
